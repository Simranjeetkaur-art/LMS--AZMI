{{!
    @template format_emd/course_header

    eMD course-home master-template header (03_SCREEN_SPECS S5). Structure +
    .az-* classes only; colour comes from theme_azmsi (_course.scss).

    Context variables required for this template:
    * title - Course full name
    * code - Course code (e.g. EMD-101)
    * credits - Credit count (int, may be null)
    * faculty - Faculty name (may be empty)
    * hasprogress - bool, whether a completion percentage is available
    * progress - completion percent (int)
    * hasgrade - bool, whether a current grade is available
    * grade - formatted current grade (e.g. "92.4 %")
    * canaddweek - bool, whether to show the "Add a week" action (editors only)
    * addweekurl - URL of the add-week endpoint (with sesskey)

    Example context (json):
    {
        "title": "Medical Terminology & Clinical Language",
        "code": "EMD-101",
        "credits": 4,
        "faculty": "Dr. M. Okafor",
        "hasprogress": true,
        "progress": 64,
        "hasgrade": true,
        "grade": "92.4 %",
        "canaddweek": true,
        "addweekurl": "https://example.com/course/format/emd/addweek.php?courseid=2&sesskey=abc"
    }
}}
<section class="az-coursehead az-card--teal" aria-label="{{title}}">
    <div class="az-coursehead-main">
        <div class="az-eyebrow az-coursehead-code">{{code}}</div>
        <h2 class="az-coursehead-title">{{title}}</h2>
        <div class="az-coursehead-meta az-serif">
            {{#faculty}}{{faculty}}{{/faculty}}{{#credits}} &middot; {{credits}} {{#str}}credits, format_emd{{/str}}{{/credits}}
        </div>
    </div>
    <div class="az-coursehead-stats az-kpi-strip">
        {{#hasprogress}}
            <div class="az-kpi">
                <div class="az-kpi-num">{{progress}}%</div>
                <div class="az-kpi-label">{{#str}}coursecomplete, format_emd{{/str}}</div>
            </div>
        {{/hasprogress}}
        {{#hasgrade}}
            <div class="az-kpi">
                <div class="az-kpi-num az-kpi-num--hi">{{grade}}</div>
                <div class="az-kpi-label">{{#str}}currentgrade, format_emd{{/str}}</div>
            </div>
        {{/hasgrade}}
    </div>
    {{#canaddweek}}
        <div class="az-coursehead-actions">
            <a href="{{addweekurl}}" class="btn btn-primary az-addweek">{{#str}}addweek, format_emd{{/str}}</a>
        </div>
    {{/canaddweek}}
</section>

{{! S5 right rail — instructor, grading & rubric (gradebook weights), objectives,
    latest faculty feedback. Each card renders only when it has live data. }}
<aside class="az-course-rail">
    {{#faculty}}
        <div class="az-card az-rail-card">
            <div class="az-card-head">{{#str}}instructor, format_emd{{/str}}</div>
            <div class="az-card-body"><span class="az-rail-instructor">{{faculty}}</span></div>
        </div>
    {{/faculty}}
    {{#hasweights}}
        <div class="az-card az-rail-card">
            <div class="az-card-head">{{#str}}gradingrubric, format_emd{{/str}}</div>
            <div class="az-card-body">
                {{#weights}}
                    <div class="az-rail-weight">
                        <span class="az-rail-weight-name">{{name}}</span>
                        {{#hasweight}}<span class="az-rail-weight-val">{{weight}}</span>{{/hasweight}}
                    </div>
                {{/weights}}
            </div>
        </div>
    {{/hasweights}}
    {{#feedback.has}}
        <div class="az-card az-rail-card">
            <div class="az-card-head">{{#str}}latestfeedback, format_emd{{/str}}</div>
            <div class="az-card-body">
                <div class="az-rail-feedback-item">{{feedback.item}}</div>
                <div class="az-rail-feedback-text az-serif">{{{feedback.text}}}</div>
            </div>
        </div>
    {{/feedback.has}}
    {{#hasobjectives}}
        <div class="az-card az-rail-card">
            <div class="az-card-head">{{#str}}objectives, format_emd{{/str}}</div>
            <div class="az-card-body az-rail-objectives">{{{objectives}}}</div>
        </div>
    {{/hasobjectives}}
</aside>
