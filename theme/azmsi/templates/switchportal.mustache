{{!
    @template theme_azmsi/switchportal

    Capability-gated "Switch portal" links for the dark sidebar. Rendered only
    when the user has at least one permitted link (see switch_portal renderable).

    Context variables required for this template:
    * label - Section label (localised)
    * haslinks - true when there is at least one permitted link
    * links - array of { url, label, accent } ('faculty' | 'admin' | '')

    Example context (json):
    {
        "label": "Switch portal",
        "haslinks": true,
        "links": [
            { "url": "https://example.com/local/azmsi/faculty.php", "label": "Faculty view", "accent": "faculty" },
            { "url": "https://example.com/local/azmsi/admin.php", "label": "Admin console", "accent": "admin" }
        ]
    }
}}
{{#haslinks}}
<nav class="az-switchportal" aria-label="{{label}}">
    <div class="az-switchportal-label">{{label}}</div>
    {{#links}}
        <a class="az-switchportal-link az-switchportal-{{accent}}" href="{{url}}">{{label}}</a>
    {{/links}}
</nav>
{{/haslinks}}
