{{!
    @template theme_azmsi/core/loginform (overrides core/loginform)

    AZMSI sign-in card matching design/AZMSI LMS Home.dc.html. This is the REAL
    Moodle login form (same context, logintoken, action, field names, JS) styled
    to the prototype: EMAIL / PASSWORD with inline Forgot + SHOW, gold Sign in,
    OR divider, real IdP (SSO) buttons only when configured, guest + cookies kept.

    Context is core/loginform's (logintoken, loginurl, error, info, forgotpasswordurl,
    identityproviders, hasidentityproviders, canloginasguest, canloginbyemail,
    username, maintenance, cansignup, signupurl, togglepassword, smallscreensonly).
}}
<div class="loginform az-loginform">
    {{#maintenance}}
        <div class="alert alert-danger login-maintenance">{{{maintenance}}}</div>
    {{/maintenance}}
    {{#error}}
        <div class="alert alert-danger" id="loginerrormessage" role="alert">{{error}}</div>
    {{/error}}
    {{#info}}
        <div class="alert alert-info" id="logininfomessage" role="status">{{info}}</div>
    {{/info}}

    {{#showloginform}}
        <form class="login-form az-form" action="{{loginurl}}" method="post" id="login">
            <input id="anchor" type="hidden" name="anchor" value="">
            <script>document.getElementById('anchor').value = location.hash;</script>
            <input type="hidden" name="logintoken" value="{{logintoken}}">

            <div class="az-field login-form-username">
                <label for="username" class="az-field-label">{{#str}}emaillabel, theme_azmsi{{/str}}</label>
                <input type="text" name="username" id="username" class="form-control" {{!
                    !}}value="{{username}}" placeholder="you@azmsi.com" autocomplete="username">
            </div>

            <div class="az-field login-form-password">
                <div class="az-field-row">
                    <label for="password" class="az-field-label">{{#str}}password{{/str}}</label>
                    <a class="az-field-forgot" href="{{forgotpasswordurl}}">{{#str}}forgot, theme_azmsi{{/str}}</a>
                </div>
                <input type="password" name="password" id="password" value="" class="form-control" {{!
                    !}}placeholder="{{#str}}password{{/str}}" autocomplete="current-password">
            </div>

            {{#recaptcha}}
                <div class="login-form-recaptcha mb-3">{{{recaptcha}}}</div>
            {{/recaptcha}}

            <div class="login-form-submit">
                <button class="btn btn-primary az-signin" type="submit" id="loginbtn">{{#str}}signinbtn, theme_azmsi{{/str}}</button>
            </div>
        </form>
    {{/showloginform}}

    {{#hasidentityproviders}}
        <div class="az-or"><span>{{#str}}ordivider, theme_azmsi{{/str}}</span></div>
        <div class="login-identityproviders">
            {{#identityproviders}}
                <a class="btn az-sso-btn" href="{{url}}">
                    {{#iconurl}}<img src="{{iconurl}}" alt="" width="20" height="20">{{/iconurl}}
                    {{name}}
                </a>
            {{/identityproviders}}
        </div>
    {{/hasidentityproviders}}

    {{#hasinstructions}}
        <div class="az-loginsub login-instructions">{{{instructions}}}</div>
    {{/hasinstructions}}
    {{#cansignup}}
        <div class="login-signup az-loginsub">
            <a class="btn az-sso-btn" href="{{signupurl}}">{{#str}}startsignup{{/str}}</a>
        </div>
    {{/cansignup}}

    {{#canloginasguest}}
        <div class="az-guest">
            <span class="az-loginsub">{{#str}}someallowguest{{/str}}</span>
            <form action="{{loginurl}}" method="post" id="guestlogin">
                <input type="hidden" name="logintoken" value="{{logintoken}}">
                <input type="hidden" name="username" value="guest">
                <input type="hidden" name="password" value="guest">
                <button class="btn az-sso-btn" type="submit" id="loginguestbtn">{{#str}}loginguest{{/str}}</button>
            </form>
        </div>
    {{/canloginasguest}}

    <div class="az-cookies">
        <button type="button" class="btn btn-link az-login-link" {{!
        }} data-modal="alert"{{!
        }} data-modal-title-str='["cookiesenabled", "core"]' {{!
        }} data-modal-content-str='["cookiesenabled_help_html", "core"]'{{!
        }}>{{#str}}cookiesnotice{{/str}}</button>
    </div>
</div>

{{#js}}
    {{^error}}
        {{#autofocusform}}
            require(['core_form/events'], function(FormEvent) {
                function autoFocus() {
                    const userNameField = document.getElementById('username');
                    const passwordField = document.getElementById('password');
                    if (userNameField && userNameField.value.length == 0) {
                        userNameField.focus();
                    } else if (passwordField) {
                        passwordField.focus();
                    }
                }
                autoFocus();
                window.addEventListener(FormEvent.eventTypes.fieldStructureChanged, autoFocus);
            });
        {{/autofocusform}}
    {{/error}}
    require(['core/pending'], function(Pending) {
        const errorMessageDiv = document.getElementById('loginerrormessage');
        const infoMessageDiv = document.getElementById('logininfomessage');
        const errorMessage = errorMessageDiv?.textContent.trim();
        const infoMessage = infoMessageDiv?.textContent.trim();
        if (errorMessage || infoMessage) {
            const pendingJS = new Pending('login-move-focus');
            const usernameField = document.getElementById('username');
            setTimeout(function() {
                if (errorMessage && usernameField) {
                    usernameField.focus();
                }
                if (errorMessage) {
                    errorMessageDiv.innerHTML += "&nbsp;";
                }
                if (infoMessage) {
                    infoMessageDiv.innerHTML += "&nbsp;";
                }
                pendingJS.resolve();
            }, 500);
        }
    });
    {{#togglepassword}}
        require(['core/togglesensitive'], function(ToggleSensitive) {
            ToggleSensitive.init("password", {{smallscreensonly}});
        });
    {{/togglepassword}}
    require(['core_form/submit'], function(Submit) {
        Submit.init("loginbtn");
        {{#canloginasguest}}
            Submit.init("loginguestbtn");
        {{/canloginasguest}}
    });
{{/js}}
