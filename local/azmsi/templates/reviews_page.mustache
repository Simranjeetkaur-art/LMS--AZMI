{{!
    @template local_azmsi/reviews_page

    Review moderation list: pending course + instructor ratings with approve/reject.
}}
<div class="az-reviews">
    <p class="az-reviews-count">{{#str}}reviewspending, local_azmsi, {{count}}{{/str}}</p>
    {{^haspending}}
        <div class="az-reviews-empty">{{#str}}nopendingreviews, local_azmsi{{/str}}</div>
    {{/haspending}}
    {{#pending}}
    <div class="az-review-card">
        <div class="az-review-head">
            <span class="az-review-rater">{{ratername}}</span>
            <span class="az-review-course">{{coursename}}</span>
            <span class="az-review-date">{{date}}</span>
        </div>
        <div class="az-review-body">
            {{#hascourse}}
            <div class="az-review-line">
                <span class="az-review-label">{{#str}}coursereview, local_azmsi{{/str}}</span>
                <span class="az-review-stars">{{coursestars}}</span>
                <span class="az-review-text">{{coursereview}}</span>
            </div>
            {{/hascourse}}
            {{#hasinstructor}}
            <div class="az-review-line">
                <span class="az-review-label">{{#str}}instructorreview, local_azmsi{{/str}}</span>
                <span class="az-review-stars">{{instructorstars}}</span>
                <span class="az-review-text">{{instructorreview}}</span>
            </div>
            {{/hasinstructor}}
        </div>
        <div class="az-review-actions">
            <a class="btn btn-success btn-sm" href="{{approveurl}}">{{#str}}approve, local_azmsi{{/str}}</a>
            <a class="btn btn-outline-danger btn-sm" href="{{rejecturl}}">{{#str}}reject, local_azmsi{{/str}}</a>
        </div>
    </div>
    {{/pending}}
</div>
