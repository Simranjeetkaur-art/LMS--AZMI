{{!
    @template local_azmsi/admin_console

    Admin console (S12) — institution overview. Layout mirrors the AZMSI admin
    prototype: a 3-up widget row (courses-by-status / admissions funnel / system
    health), the course-operations table, then a 3-up row (faculty load / users by
    role / announcements). Those data widgets live in the admin_console_live partial
    and are wrapped in [data-region="azmsi-admin-live"] so the JS poller
    (local_azmsi/admin_console_live) can refresh them in place from the same
    cron/event-driven rollup — nothing on this page is hardcoded. The production
    pipeline (cap+sesskey write) and the portal switch stay outside the live region.
}}
<div class="az-admin">

    {{! ---- Reviews moderation entry ---- }}
    <section class="az-dash-section az-admin-reviews">
        <a class="az-admin-reviews-link" href="{{reviewsurl}}">
            <span>{{#str}}reviews, local_azmsi{{/str}}</span>
            {{#hasreviews}}<span class="az-admin-reviews-badge">{{reviewspending}}</span>{{/hasreviews}}
        </a>
    </section>

    <div data-region="azmsi-admin-live" data-generatedon="{{generatedon}}">
        {{> local_azmsi/admin_console_live }}
    </div>

    {{! ---- Production pipeline (collapsed behind a click so the page stays light) ---- }}
    <section class="az-dash-section">
        <details class="az-disclosure az-pipeline-disclosure">
            <summary class="az-disclosure-head">
                <span class="az-disclosure-title">{{#str}}productionpipeline, local_azmsi{{/str}}</span>
                <span class="az-disclosure-meta">
                    {{pipelinesummary.total}} {{#str}}coursesword, local_azmsi{{/str}}
                    {{#pipelinesummary.complete}}&middot; <span class="az-disclosure-done">{{pipelinesummary.complete}} {{#str}}statuscomplete, local_azmsi{{/str}}</span>{{/pipelinesummary.complete}}
                </span>
                <span class="az-disclosure-action">
                    <span class="az-disclosure-open">{{#str}}openpipeline, local_azmsi{{/str}}</span>
                    <span class="az-disclosure-close">{{#str}}closepipeline, local_azmsi{{/str}}</span>
                    <span class="az-disclosure-chevron" aria-hidden="true">&#9656;</span>
                </span>
            </summary>
            <div class="az-disclosure-body">
                {{> local_azmsi/admin_pipeline }}
            </div>
        </details>
    </section>
</div>
{{#js}}
require(['local_azmsi/admin_console_live'], function(Live) {
    Live.init({{refreshseconds}});
});
{{/js}}
