<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="local/azmsi/db" VERSION="20260616" COMMENT="AZMSI custom tables: research tracker, production pipeline, admissions application (AGENT_03)."
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
  <TABLES>
    <TABLE NAME="local_azmsi_research" COMMENT="One dissertation/research record per student (seeded when enrolled in Q10+).">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Student user id."/>
        <FIELD NAME="mentorid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Research mentor user id."/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Anchor course (dissertation course) if any."/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="track" TYPE="char" LENGTH="64" NOTNULL="false" SEQUENCE="false" COMMENT="Research track / specialisation."/>
        <FIELD NAME="status" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="active" SEQUENCE="false" COMMENT="active|on_hold|complete"/>
        <FIELD NAME="progress" TYPE="int" LENGTH="3" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Percent 0-100, recomputed from milestones."/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="status" UNIQUE="false" FIELDS="status"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_azmsi_research_milestone" COMMENT="Ordered milestones belonging to a research record (AGENT_03 §3).">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="researchid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="seq" TYPE="int" LENGTH="5" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="Display order."/>
        <FIELD NAME="title" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="descr" TYPE="text" NOTNULL="false" SEQUENCE="false" COMMENT="Milestone description."/>
        <FIELD NAME="status" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="pending" SEQUENCE="false" COMMENT="pending|active|submitted|approved"/>
        <FIELD NAME="due" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Due date (timestamp)."/>
        <FIELD NAME="completedon" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Completion date (timestamp)."/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="researchid" TYPE="foreign" FIELDS="researchid" REFTABLE="local_azmsi_research" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_azmsi_research_doc" COMMENT="Documents attached to a research record, with Turnitin status (AGENT_03 §3).">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="researchid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="filename" TYPE="char" LENGTH="255" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="type" TYPE="char" LENGTH="32" NOTNULL="false" SEQUENCE="false" COMMENT="Document type, e.g. proposal|chapter|dissertation."/>
        <FIELD NAME="status" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="draft" SEQUENCE="false" COMMENT="draft|submitted|reviewed"/>
        <FIELD NAME="turnitin_status" TYPE="char" LENGTH="32" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="researchid" TYPE="foreign" FIELDS="researchid" REFTABLE="local_azmsi_research" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_azmsi_pipeline" COMMENT="Per-course 6-stage production pipeline (03_SCREEN_SPECS.md).">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="stage_sme" TYPE="char" LENGTH="16" NOTNULL="true" DEFAULT="queued" SEQUENCE="false" COMMENT="queued|active|done"/>
        <FIELD NAME="stage_id" TYPE="char" LENGTH="16" NOTNULL="true" DEFAULT="queued" SEQUENCE="false"/>
        <FIELD NAME="stage_video" TYPE="char" LENGTH="16" NOTNULL="true" DEFAULT="queued" SEQUENCE="false"/>
        <FIELD NAME="stage_build" TYPE="char" LENGTH="16" NOTNULL="true" DEFAULT="queued" SEQUENCE="false"/>
        <FIELD NAME="stage_qa" TYPE="char" LENGTH="16" NOTNULL="true" DEFAULT="queued" SEQUENCE="false"/>
        <FIELD NAME="stage_launch" TYPE="char" LENGTH="16" NOTNULL="true" DEFAULT="queued" SEQUENCE="false"/>
        <FIELD NAME="updatedby" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="User id who last updated a stage."/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign-unique" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
      </KEYS>
    </TABLE>
    <TABLE NAME="local_azmsi_application" COMMENT="Admissions application + AQE stage (AGENT_08; required at AGENT_03).">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="Applicant user id."/>
        <FIELD NAME="program" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="eMD" SEQUENCE="false" COMMENT="Applied program code."/>
        <FIELD NAME="stage" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="applied" SEQUENCE="false" COMMENT="applied|aqe_scheduled|aqe_completed|review|decision"/>
        <FIELD NAME="status" TYPE="char" LENGTH="32" NOTNULL="true" DEFAULT="open" SEQUENCE="false" COMMENT="open|accepted|rejected|withdrawn"/>
        <FIELD NAME="aqe_quizid" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="AQE quiz id (mod_quiz)."/>
        <FIELD NAME="aqe_slot" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Scheduled AQE datetime (timestamp)."/>
        <FIELD NAME="decision" TYPE="char" LENGTH="32" NOTNULL="false" SEQUENCE="false" COMMENT="accepted|rejected|waitlist."/>
        <FIELD NAME="decisioneta" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false" COMMENT="Decision ETA (timestamp)."/>
        <FIELD NAME="submittedon" TYPE="int" LENGTH="10" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="aqe_quizid" TYPE="foreign" FIELDS="aqe_quizid" REFTABLE="quiz" REFFIELDS="id"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="stage" UNIQUE="false" FIELDS="stage"/>
      </INDEXES>
    </TABLE>
    <TABLE NAME="local_azmsi_review" COMMENT="Learner course + instructor star ratings/reviews, moderated by managers (AGENT_05 Phase 3).">
      <FIELDS>
        <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true"/>
        <FIELD NAME="courseid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false"/>
        <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="false" COMMENT="The learner who submitted the rating."/>
        <FIELD NAME="instructorid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="The instructor being rated (0 if none)."/>
        <FIELD NAME="coursestars" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="1-5, 0 = not rated."/>
        <FIELD NAME="coursereview" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="instructorstars" TYPE="int" LENGTH="2" NOTNULL="true" DEFAULT="0" SEQUENCE="false" COMMENT="1-5, 0 = not rated."/>
        <FIELD NAME="instructorreview" TYPE="text" NOTNULL="false" SEQUENCE="false"/>
        <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="pending" SEQUENCE="false" COMMENT="pending|approved|rejected"/>
        <FIELD NAME="approvedby" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timeapproved" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
        <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" SEQUENCE="false"/>
      </FIELDS>
      <KEYS>
        <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
        <KEY NAME="courseid" TYPE="foreign" FIELDS="courseid" REFTABLE="course" REFFIELDS="id"/>
        <KEY NAME="userid" TYPE="foreign" FIELDS="userid" REFTABLE="user" REFFIELDS="id"/>
        <KEY NAME="courseuser" TYPE="unique" FIELDS="courseid, userid"/>
      </KEYS>
      <INDEXES>
        <INDEX NAME="instructorstatus" UNIQUE="false" FIELDS="instructorid, status"/>
        <INDEX NAME="coursestatus" UNIQUE="false" FIELDS="courseid, status"/>
      </INDEXES>
    </TABLE>
  </TABLES>
</XMLDB>
