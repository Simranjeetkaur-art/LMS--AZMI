{{!
    @template block_azmsi_dashboard/dashboard

    AZMSI student dashboard (S4). All values come from the shared local_azmsi overview
    composition (live completion, gradebook, calendar, custom fields). No switch
    portal and no admissions content on this page.
}}
<div class="az-dashboard">

    <header class="az-dash-greeting">
        <h1 class="az-dash-hello">{{#str}}greeting, block_azmsi_dashboard, {{firstname}}{{/str}}</h1>
        {{#programsubtitle}}<p class="az-dash-subtitle">{{programsubtitle}}</p>{{/programsubtitle}}
    </header>

    {{#continue.has}}
    <section class="az-continue-banner" aria-label="{{#str}}continue, block_azmsi_dashboard{{/str}}">
        <div class="az-continue-body">
            <div class="az-continue-eyebrow">{{#str}}continue, block_azmsi_dashboard{{/str}}{{#continue.coursecode}} &middot; {{continue.coursecode}}{{/continue.coursecode}}</div>
            <div class="az-continue-title">{{{continue.name}}}</div>
            {{#continue.progresstext}}<p class="az-continue-meta">{{continue.progresstext}}</p>{{/continue.progresstext}}
            <a class="az-cta" href="{{continue.url}}">{{continue.resumelabel}} &rarr;</a>
        </div>
        <div class="az-continue-stats az-kpi-strip">
            <div class="az-kpi">
                <div class="az-kpi-num">{{modulescompleted}}</div>
                <div class="az-kpi-label">{{#str}}modulescompleted, block_azmsi_dashboard{{/str}}</div>
            </div>
            <div class="az-kpi">
                <div class="az-kpi-num">{{duecount}}</div>
                <div class="az-kpi-label">{{#str}}duethisweek, block_azmsi_dashboard{{/str}}</div>
            </div>
            {{#hasaverage}}
            <div class="az-kpi">
                <div class="az-kpi-num az-kpi-num--hi">{{average}}</div>
                <div class="az-kpi-label">{{#str}}currentaverage, block_azmsi_dashboard{{/str}}</div>
            </div>
            {{/hasaverage}}
        </div>
    </section>
    {{/continue.has}}

    {{#hascourses}}
    <section class="az-dash-section">
        <div class="az-dash-section-head">
            <h2 class="az-dash-section-title">{{inprogresstitle}}</h2>
            {{#inprogressmeta}}<span class="az-eyebrow">{{inprogressmeta}}</span>{{/inprogressmeta}}
        </div>
        <div class="az-dash-cards">
            {{#courses}}
            <a class="az-course-card {{#isprimary}}az-course-card--primary{{/isprimary}}" href="{{url}}">
                <div class="az-course-card-top">
                    <span class="az-course-code">&#9656; {{code}}</span>
                    <span class="az-pill az-pill--{{#isprimary}}gold{{/isprimary}}{{^isprimary}}mute{{/isprimary}}">{{weeklabel}}</span>
                </div>
                <div class="az-course-card-body">
                    <div class="az-course-name">{{name}}</div>
                    {{#hasinstructor}}<div class="az-course-meta">{{instructor}}{{#hascredits}} &middot; {{credits}} {{#str}}credits, block_azmsi_dashboard{{/str}}{{/hascredits}}</div>{{/hasinstructor}}
                    {{^hasinstructor}}{{#hascredits}}<div class="az-course-meta">{{credits}} {{#str}}credits, block_azmsi_dashboard{{/str}}</div>{{/hascredits}}{{/hasinstructor}}
                </div>
                <div class="az-course-card-foot">
                    <div class="az-progress"><div class="az-progress-fill" style="--az-pct:{{progress}}%"></div></div>
                    <div class="az-course-card-footrow">
                        <span class="az-course-progresslabel">{{progress}}% {{#str}}completeupper, block_azmsi_dashboard{{/str}}</span>
                        <span class="az-course-open">{{#str}}open, block_azmsi_dashboard{{/str}} &rarr;</span>
                    </div>
                </div>
            </a>
            {{/courses}}
        </div>
    </section>
    {{/hascourses}}

    <div class="az-dash-bottom">
        <section class="az-card az-dueweek">
            <div class="az-card-head az-card-head--split">
                <span>{{#str}}duethisweek, block_azmsi_dashboard{{/str}}</span>
                {{#duerange}}<span class="az-card-head-meta">{{duerange}}</span>{{/duerange}}
            </div>
            <div class="az-card-body az-dueweek-body">
                {{#dueweek}}
                <a class="az-due-row" href="{{url}}">
                    <span class="az-due-type az-due-type--{{typeclass}}">{{typelabel}}</span>
                    <span class="az-due-id">
                        <span class="az-due-name">{{name}}</span>
                        {{#coursecode}}<span class="az-due-meta">{{coursecode}}</span>{{/coursecode}}
                    </span>
                    <span class="az-due-when">{{dueshort}}</span>
                </a>
                {{/dueweek}}
                {{^hasdueweek}}<p class="az-text-mute">{{#str}}noduelist, block_azmsi_dashboard{{/str}}</p>{{/hasdueweek}}
            </div>
        </section>

        {{#hasjourney}}
        <section class="az-card az-journey">
            <div class="az-card-head">
                <span class="az-journey-title">{{#str}}emdjourney, block_azmsi_dashboard{{/str}}</span>
                <span class="az-journey-sub">{{#str}}emdjourneysub, block_azmsi_dashboard{{/str}}</span>
            </div>
            <div class="az-card-body">
                <div class="az-journey-chips">
                    {{#journey.quarters}}
                    <span class="az-journey-chip az-journey-chip--{{status}}{{#highlight}} az-journey-chip--hi{{/highlight}}">{{label}}</span>
                    {{/journey.quarters}}
                </div>
                <div class="az-journey-progress">
                    <div class="az-journey-progress-head">
                        <span>{{#str}}programprogress, block_azmsi_dashboard{{/str}}</span>
                        <span class="az-journey-progress-val">{{journey.programprogresslabel}}</span>
                    </div>
                    <div class="az-progress"><div class="az-progress-fill az-progress-fill--gold" style="--az-pct:{{journey.programprogress}}%"></div></div>
                </div>
                {{#hasnextliveclass}}
                <div class="az-journey-live">
                    <span class="az-journey-live-cap">{{#str}}nextliveclass, block_azmsi_dashboard{{/str}}</span>
                    <span class="az-journey-live-text">{{journey.nextliveclass.text}}</span>
                </div>
                {{/hasnextliveclass}}
            </div>
        </section>
        {{/hasjourney}}
    </div>
</div>
