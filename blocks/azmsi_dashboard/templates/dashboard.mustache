{{!
    @template block_azmsi_dashboard/dashboard

    AZMSI student dashboard (03_SCREEN_SPECS S4). All values come from the shared
    local_azmsi overview composition (live completion/gradebook/calendar/customfields).

    Context: firstname, fullname, average, hasaverage, modulescompleted, coursecount,
    continue{has,name,coursename,url}, courses[{code,name,credits,progress,status,url}],
    dueweek[{name,url,due}], hasdueweek, duecount, programmap[{quarter,status,current}],
    switchportal{label,links[]}, hasswitchportal.
}}
<div class="az-dashboard">

    <header class="az-dash-greeting">
        <h1 class="az-dash-hello">{{#str}}greeting, block_azmsi_dashboard, {{firstname}}{{/str}}</h1>
    </header>

    {{#continue.has}}
    <section class="az-continue-banner" aria-label="{{#str}}continue, block_azmsi_dashboard{{/str}}">
        <div class="az-continue-body">
            <div class="az-continue-eyebrow">{{#str}}continue, block_azmsi_dashboard{{/str}} &middot; {{continue.coursename}}</div>
            <div class="az-continue-title">{{continue.name}}</div>
            <a class="az-cta" href="{{continue.url}}">{{#str}}resume, block_azmsi_dashboard{{/str}} &rarr;</a>
        </div>
        <div class="az-continue-stats az-kpi-strip">
            <div class="az-kpi">
                <div class="az-kpi-num">{{modulescompleted}}</div>
                <div class="az-kpi-label">{{#str}}modulescompleted, block_azmsi_dashboard{{/str}}</div>
            </div>
            <div class="az-kpi">
                <div class="az-kpi-num">{{duecount}}</div>
                <div class="az-kpi-label">{{#str}}duethisweek, block_azmsi_dashboard{{/str}}</div>
            </div>
            {{#hasaverage}}
            <div class="az-kpi">
                <div class="az-kpi-num az-kpi-num--hi">{{average}}</div>
                <div class="az-kpi-label">{{#str}}currentaverage, block_azmsi_dashboard{{/str}}</div>
            </div>
            {{/hasaverage}}
        </div>
    </section>
    {{/continue.has}}

    {{#hascourses}}
    <section class="az-dash-section">
        <div class="az-dash-section-head">
            <h2 class="az-dash-section-title">{{#str}}inprogress, block_azmsi_dashboard{{/str}}</h2>
            <span class="az-eyebrow">{{coursecount}} {{#str}}courses, block_azmsi_dashboard{{/str}}</span>
        </div>
        <div class="az-dash-cards">
            {{#courses}}
            <a class="az-course-card" href="{{url}}">
                <div class="az-course-card-top">
                    <span class="az-course-code">&#9656; {{code}}</span>
                    {{#status_inprogress}}<span class="az-pill az-pill--gold">{{statuslabel}}</span>{{/status_inprogress}}
                    {{^status_inprogress}}<span class="az-pill az-pill--mute">{{statuslabel}}</span>{{/status_inprogress}}
                </div>
                <div class="az-course-card-body">
                    <div class="az-course-name">{{name}}</div>
                    {{#hascredits}}<div class="az-course-meta">{{credits}} {{#str}}credits, block_azmsi_dashboard{{/str}}</div>{{/hascredits}}
                </div>
                <div class="az-course-card-foot">
                    <div class="az-progress"><div class="az-progress-fill" style="--az-pct:{{progress}}%"></div></div>
                    <div class="az-course-progresslabel">{{progress}}% {{#str}}complete, block_azmsi_dashboard{{/str}}</div>
                </div>
            </a>
            {{/courses}}
        </div>
    </section>
    {{/hascourses}}

    {{#hasdueweek}}
    <section class="az-dash-section">
        <h2 class="az-dash-section-title">{{#str}}duethisweek, block_azmsi_dashboard{{/str}}</h2>
        <ul class="az-checklist">
            {{#dueweek}}
            <li class="az-check az-check--due">
                <span class="az-check-mark">&#9656;</span>
                <a class="az-check-link" href="{{url}}">{{name}}</a>
                <span class="az-check-due">{{due}}</span>
            </li>
            {{/dueweek}}
        </ul>
    </section>
    {{/hasdueweek}}

    <section class="az-dash-section">
        <h2 class="az-dash-section-title">{{#str}}programmap, block_azmsi_dashboard{{/str}}</h2>
        <ol class="az-progmap">
            {{#programmap}}
            <li class="az-progmap-q az-progmap-q--{{status}} {{#current}}az-progmap-q--current{{/current}}">
                <span class="az-progmap-num">{{#str}}quartern, block_azmsi_dashboard, {{quarter}}{{/str}}</span>
            </li>
            {{/programmap}}
        </ol>
    </section>

    {{#hasswitchportal}}
        {{> theme_azmsi/switchportal }}
    {{/hasswitchportal}}
</div>
