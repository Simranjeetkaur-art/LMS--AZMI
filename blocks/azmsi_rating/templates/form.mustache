{{!
    @template block_azmsi_rating/form

    Course + instructor rating form for enrolled learners.
}}
<form method="post" action="{{actionurl}}" class="az-rateform">
    <input type="hidden" name="courseid" value="{{courseid}}">
    <input type="hidden" name="sesskey" value="{{sesskey}}">
    {{#hasstatus}}<div class="az-rate-status">{{statusmsg}}</div>{{/hasstatus}}
    <p class="az-rate-intro">{{intro}}</p>

    <fieldset class="az-rate-group">
        <legend>{{#str}}ratecourse, local_azmsi{{/str}}</legend>
        <div class="az-stars">
            {{#coursestars}}
            <label class="az-star"><input type="radio" name="coursestars" value="{{value}}" {{#checked}}checked{{/checked}}><span>{{value}}&#9733;</span></label>
            {{/coursestars}}
        </div>
        <label class="sr-only" for="az-coursereview">{{#str}}reviewbody, local_azmsi{{/str}}</label>
        <textarea id="az-coursereview" name="coursereview" rows="2" placeholder="{{#str}}reviewbody, local_azmsi{{/str}}">{{coursereview}}</textarea>
    </fieldset>

    <fieldset class="az-rate-group">
        <legend>{{#str}}rateinstructor, local_azmsi{{/str}}</legend>
        <div class="az-stars">
            {{#instructorstars}}
            <label class="az-star"><input type="radio" name="instructorstars" value="{{value}}" {{#checked}}checked{{/checked}}><span>{{value}}&#9733;</span></label>
            {{/instructorstars}}
        </div>
        <label class="sr-only" for="az-instructorreview">{{#str}}reviewbody, local_azmsi{{/str}}</label>
        <textarea id="az-instructorreview" name="instructorreview" rows="2" placeholder="{{#str}}reviewbody, local_azmsi{{/str}}">{{instructorreview}}</textarea>
    </fieldset>

    <button type="submit" class="btn btn-primary btn-sm">{{#str}}reviewsubmit, local_azmsi{{/str}}</button>
</form>
